<IfModule mod_rewrite.c>
    RewriteEngine On

    # Keep Laravel's public directory out of browser-facing URLs.
    # THE_REQUEST ensures this only redirects direct client requests and does
    # not interfere with the internal rewrite to public/ below.
    RewriteCond %{THE_REQUEST} \s/+public(?:[/?\s]) [NC]
    RewriteRule ^public(?:/(.*))?$ /$1 [R=301,L,NE]

    # Internally serve the application from Laravel's public directory.
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
